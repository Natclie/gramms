---
import { createClient } from '@supabase/supabase-js';
const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);

const { count } = await supabase
  .from('urls')
  .select('*', { count: 'exact', head: true });
---
<footer class="fixed bottom-0 w-full border-t border-slate-800/80 bg-slate-950/85 px-4 py-3 text-slate-300 backdrop-blur-sm">
  <div class=" flex  flex-col items-center justify-between gap-2 text-sm sm:flex-row">
    <a href="/" class="flex items-center gap-2 rounded-full border border-slate-800 bg-slate-900/80 px-3 py-2 transition hover:border-cyan-400/30 hover:bg-slate-800">
      <img class="w-6" src="/github.svg" alt="GitHub">
      Rate on GitHub
    </a>
    <p class="text-slate-400">
      <span class="font-semibold text-slate-200">{count}</span> URLs acortadas en toda la aplicación.
    </p>
  </div>
</footer>